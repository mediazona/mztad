{
  "name": "mztad",
  "version": "0.1.0",
  "description": "Fast DuckDB-backed viewer for CSV/TSV/JSON/Parquet files",
  "type": "module",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "dist": "electron-vite build && electron-builder --mac",
    "dist:dir": "electron-vite build && electron-builder --mac --dir",
    "dist:universal": "electron-vite build && electron-builder --mac --arm64 --x64",
    "prepare:win": "node scripts/install-duckdb-binding.mjs win32-x64",
    "dist:win": "npm run prepare:win && electron-vite build && electron-builder --win",
    "dist:win:dir": "npm run prepare:win && electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.2-r.1",
    "ag-grid-community": "^33.0.0",
    "ag-grid-react": "^33.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.mzTad.app",
    "productName": "mzTad",
    "icon": "public/icon.png",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/@duckdb/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "mzTad"
    }
  }
}
